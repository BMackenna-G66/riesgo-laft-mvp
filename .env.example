# ─────────────────────────────────────────────────────────────────────────────
# Redshift — autenticación IAM (sin contraseñas estáticas)
# ─────────────────────────────────────────────────────────────────────────────
REDSHIFT_HOST=compliance-redshift-cluster.cszw4nrem7jk.us-east-1.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=dev
REDSHIFT_CLUSTER_ID=compliance-redshift-cluster
AWS_REGION=us-east-1

# IAM credentials del usuario compliance_admin
# Obtener desde: AWS Console → IAM → compliance_admin → Claves de acceso
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Usuario IAM mapeado en Redshift (formato: IAM:nombre_usuario)
# Si usas usuario de DB tradicional, usa solo el nombre sin prefijo IAM:
REDSHIFT_DB_USER=compliance_admin

# Prefijo de base de datos en las queries (db_prod en producción, dev en este cluster)
# Usado para parametrizar las 5 queries SQL: "db_prod"."schema"."tabla"
REDSHIFT_DB_PREFIX=dev

# ─────────────────────────────────────────────────────────────────────────────
# Configuración del pipeline
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MODEL_VERSION=1.0.0
LOOKBACK_DAYS=180
